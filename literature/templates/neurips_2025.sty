% NeurIPS 2025 LaTeX Style File
% Minimal implementation for literature review system
% Based on NeurIPS conference style guidelines

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 style]

% Options
\newif\if@preprint
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@preprintfalse}
\ExecuteOptions{final}

\ProcessOptions\relax

% Page layout
\RequirePackage[margin=1in]{geometry}
\RequirePackage{setspace}
\onehalfspacing

% Typography
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}

% Math
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsfonts}

% Graphics and colors
\RequirePackage{graphicx}
\RequirePackage{xcolor}

% Bibliography
\RequirePackage{natbib}
\bibliographystyle{plainnat}

% Hyperlinks
\RequirePackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  citecolor=blue,
  urlcolor=blue
}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Title and author formatting
\renewcommand{\maketitle}{%
  \begin{center}
    {\Large\bfseries\@title\par}
    \vspace{0.5em}
    {\normalsize\@author\par}
    \vspace{0.5em}
    {\normalsize\@date\par}
  \end{center}
  \vspace{1em}
}

% Abstract environment
\renewenvironment{abstract}{%
  \begin{center}
    \bfseries Abstract
  \end{center}
  \begin{quote}
}{%
  \end{quote}
}

% Preprint notice
\if@preprint
  \RequirePackage{fancyhdr}
  \pagestyle{fancy}
  \lhead{\small Preprint}
  \rhead{\small \today}
  \cfoot{\small Page \thepage}
\fi

\endinput
